#ifndef GCU_TRANSFORMS_PASSES
#define GCU_TRANSFORMS_PASSES

include "Dialect/GCUWS/IR/GCUWSDialect.td"
include "mlir/Pass/PassBase.td"
include "triton/Dialect/Triton/IR/TritonOps.td"
include "triton/Dialect/TritonGPU/IR/TritonGPUDialect.td"

def GCU64TypeVerifierPass: Pass<"gcu64-type-verifier", "gpu::GPUModuleOp"> {
  let summary = "Verify that all types are GCU64 types.";
  let description = "Verify that no 64bit type on func arguments.";
  let dependentDialects = [
    "gpu::GPUDialect",
    "triton::TritonDialect",
  ];
  let options = [
    Option<"arch", "arch", "std::string",
           /*default=*/"\"gcu400\"",
           "Architecture that these operations will run on">,
    Option<"test_mode", "test-mode", "bool", /*default=*/"false",
           "test mode for filecheck">
  ];
}

def GCUCombineOps : Pass<"gcu-combine-ops", "gpu::GPUModuleOp"> {
  let summary = "combine ops";
  let description = [{
    This pass aims to optimize the specific patterns.
  }];

  let dependentDialects = [
    "mlir::arith::ArithDialect",
    "mlir::math::MathDialect",
    "triton::TritonDialect"
  ];

  let options = [
    Option<"enableIntegerMixedPrecision", "enable-integer-mixed-precision", "bool",
           /*default=*/ "false", "enable integer mixed precision">
  ];
}

def GCUWarpSpecialization : Pass<"gcu-warp-specialization", "mlir::ModuleOp"> {
  let summary = "Automatic Warp specialization for GCU";

  let description = [{
    This pass automatically partitions user-defined kernels into
    warp-specialized kernels, enabling finer-grained scheduling
    and improved utilization of hardware resources.
  }];

  let dependentDialects = [
    "mlir::triton::gpu::TritonGPUDialect",
    "mlir::triton::gcuws::GCUWSDialect",
  ];

  let options = [
    Option<"numStages", "num-stages",
           "int32_t", /*default*/"0",
           "number of buffers for warp specialization">,
    Option<"dumpIntermediateSteps", "dump-intermediate-steps",
           "bool", /*default*/"false",
           "Dump intermediate steps">,
    Option<"innerBarrier", "inner-barrier",
           "bool", /*default*/"false",
           "Insert inner barrier">
  ];
}

def GCUTleLowerAsyncLoad
    : Pass<"gcu-tle-lower-async-load", "mlir::ModuleOp"> {
  let summary = "Lower TLE async load operations";

  let description = [{
    This pass lowers tl::LoadOp with tt.load.async to target-specific GPU operations by converting
    high-level asynchronous load operations into appropriate TritonGPU primitives.
  }];

  let dependentDialects = ["mlir::triton::gpu::TritonGPUDialect",
                           "mlir::triton::TritonDialect"];
}

def GCUTestWSTaskPartition : Pass<"gcu-test-ws-task-partition", "mlir::ModuleOp"> {
  let summary = "test warp specialization task partition";

  let description = [{
    This pass computes a warp schedule partition by annoating anchor operations
    with async task ids.
  }];

  let dependentDialects = [
    "mlir::triton::gpu::TritonGPUDialect",
  ];

  let options = [
    Option<"numWarpGroups", "num-warp-groups",
           "int32_t", /*default*/"0",
           "number of warp groups for warp specialization">
  ];
}

def GCUTestWSTaskIdPropagate : Pass<"gcu-test-ws-taskid-propagate", "mlir::ModuleOp"> {
  let summary = "test warp specialization task id propagation";

  let description = [{
    This pass propagates the `async_task_id` annotation to the dependencies
    of any op that has it set.  This has the functional effect of partitioning
    the graph into multiple async tasks, based on the initial annotation.
  }];

  let dependentDialects = [
    "mlir::triton::gpu::TritonGPUDialect",
  ];

  let options = [
    Option<"numWarpGroups", "num-warp-groups",
           "int32_t", /*default*/"0",
           "number of warp groups for warp specialization">
  ];
}

def GCUTestWSCodePartition: Pass<"gcu-test-ws-code-partition", "mlir::ModuleOp"> {
  let summary = "test warp specialization code partition";

  let description = [{
    This pass generates warp specialized code baed on task id attributes.
  }];

  let dependentDialects = [
    "mlir::triton::gpu::TritonGPUDialect",
    "mlir::triton::gcuws::GCUWSDialect",
    // "mlir::triton::nvidia_gpu::TritonNvidiaGPUDialect",
  ];

  let options = [
    Option<"numBuffers", "num-buffers",
           "int32_t", /*default*/"0",
           "number of buffering for producer-consumer">,
    Option<"numWarps", "num-warps",
           "int32_t", /*default*/"0",
           "number of warps for warp specialization">,
    Option<"numWarpGroups", "num-warp-groups",
           "int32_t", /*default*/"0",
           "number of warp groups for warp specialization">,
    Option<"innerBarrier", "inner-barrier",
           "bool", /*default*/"false",
           "Insert inner barrier">
  ];
}

#endif // GCU_TRANSFORMS_PASSES
